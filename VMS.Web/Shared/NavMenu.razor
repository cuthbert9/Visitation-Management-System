@inject NavigationManager NavigationManager
@inject VMS.Web.Auth.MockAuthService MockAuth

<div class="bg-dark text-white p-3" style="width: 280px;">
    <h4 class="mb-1">VMS</h4>
    <p class="small text-white-50 mb-4">@MockAuth.CurrentSession?.DisplayName</p>

    <nav class="nav flex-column gap-2">
        @if (CanAccess(DemoPermissions.VisitsRead))
        {
            <NavLink class="nav-link text-white" href="/visits" Match="NavLinkMatch.All">Visits</NavLink>
        }

        @if (CanAccess(DemoPermissions.VisitsCreate))
        {
            <NavLink class="nav-link text-white" href="/visits/create">Schedule Visit</NavLink>
        }

        @if (CanAccess(DemoPermissions.VisitorsRead))
        {
            <NavLink class="nav-link text-white" href="/visitors" Match="NavLinkMatch.All">Visitors</NavLink>
        }

        @if (CanAccess(DemoPermissions.VisitorsCreate))
        {
            <NavLink class="nav-link text-white" href="/visitors/create">Add Visitor</NavLink>
        }

        @if (CanAccess(DemoPermissions.OfficesRead))
        {
            <NavLink class="nav-link text-white" href="/offices" Match="NavLinkMatch.All">Offices</NavLink>
        }

        @if (CanAccess(DemoPermissions.OfficesManage))
        {
            <NavLink class="nav-link text-white" href="/offices/create">Add Office</NavLink>
        }
    </nav>

    <div class="mt-4 pt-3 border-top border-secondary d-grid gap-2">
       
        <button class="btn btn-danger btn-sm" @onclick="LogoutAsync">Exit </button>
    </div>
</div>

@code {
    private bool CanAccess(string permission) => MockAuth.HasPermission(permission);

    private void SwitchRole()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task LogoutAsync()
    {
        await MockAuth.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }
}
