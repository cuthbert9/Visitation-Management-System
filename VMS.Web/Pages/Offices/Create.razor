@page "/offices/create"
@inject VMS.Web.Services.IOfficeService OfficeService
@inject NavigationManager NavigationManager

<PageTitle>Create Office</PageTitle>

<h1 class="mb-4">Create Office</h1>

<div class="card shadow-sm">
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <EditForm Model="request" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="request.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Location</label>
                <InputText class="form-control" @bind-Value="request.Location" />
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <InputSelect class="form-select" @bind-Value="request.Status">
                    @foreach (var status in Enum.GetValues<OfficeStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </InputSelect>
            </div>

            <button class="btn btn-primary" type="submit" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Create Office")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private CreateOfficeDto request = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task HandleSubmitAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            await OfficeService.CreateOfficeAsync(request);
            NavigationManager.NavigateTo("/offices");
        }
        catch
        {
            errorMessage = "Failed to create office.";
        }
        finally
        {
            isSaving = false;
        }
    }
}
