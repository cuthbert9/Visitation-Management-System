@page "/offices"
@inject VMS.Web.Services.IOfficeService OfficeService

<PageTitle>Offices</PageTitle>

<h1 class="mb-4">Offices</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Available offices and their status.</p>
    <a class="btn btn-primary" href="/offices/create">New Office</a>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (offices.Count == 0)
{
    <div class="alert alert-info">No offices found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var office in offices)
                {
                    <tr>
                        <td>@office.Name</td>
                        <td>@office.Location</td>
                        <td>@office.Status</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary" href="/offices/@office.Id">View</a>
                                <a class="btn btn-outline-secondary" href="/offices/@office.Id/edit">Edit</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<OfficeDto> offices = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            offices = (await OfficeService.GetOfficesAsync()).ToList();
        }
        catch
        {
            errorMessage = "Failed to load offices.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
