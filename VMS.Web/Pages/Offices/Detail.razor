@page "/offices/{Id:int}"
@inject VMS.Web.Services.IOfficeService OfficeService
@inject NavigationManager NavigationManager

<PageTitle>Office Details</PageTitle>

<h1 class="mb-4">Office Details</h1>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (office is null)
{
    <div class="alert alert-warning">Office not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <p class="text-muted mb-0">Office profile and visit history.</p>
        <div class="btn-group">
            <a class="btn btn-outline-secondary" href="/offices/@office.Id/edit">Edit</a>
            <button class="btn btn-outline-danger" @onclick="DeleteOfficeAsync" disabled="@isDeleting">
                @(isDeleting ? "Deleting..." : "Delete")
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@office.Name</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@office.Location</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@office.Status</dd>
            </dl>
        </div>
    </div>

    <h2 class="h4 mb-3">Visits</h2>

    @if (visits.Count == 0)
    {
        <div class="alert alert-info">This office has no visits yet.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Visitor</th>
                            <th>Visit Date</th>
                            <th>Status</th>
                            <th>Purpose</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var visit in visits)
                    {
                        <tr>
                            <td>@visit.Visitor.FullName</td>
                            <td>@visit.VisitDate.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td>@visit.Status</td>
                            <td>@visit.Purpose</td>
                            <td><a class="btn btn-sm btn-outline-primary" href="/visits/@visit.Id">View</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private OfficeDto? office;
    private List<VisitDto> visits = [];
    private bool isLoading = true;
    private bool isDeleting;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            office = await OfficeService.GetOfficeByIdAsync(Id);
            visits = office is null ? [] : (await OfficeService.GetOfficeVisitsAsync(Id)).ToList();
        }
        catch
        {
            errorMessage = "Failed to load office details.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteOfficeAsync()
    {
        if (office is null)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        try
        {
            await OfficeService.DeleteOfficeAsync(office.Id);
            NavigationManager.NavigateTo("/offices");
        }
        catch
        {
            errorMessage = "Failed to delete office. It may still have visits attached.";
        }
        finally
        {
            isDeleting = false;
        }
    }
}
