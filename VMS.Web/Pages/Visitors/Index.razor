@page "/visitors"
@inject VMS.Web.Services.IVisitorService VisitorService
@inject VMS.Web.Auth.MockAuthService MockAuth

<PageTitle>Visitors</PageTitle>

<h1 class="mb-4">Visitors</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">All registered visitors.</p>
    @if (MockAuth.HasPermission(DemoPermissions.VisitorsCreate))
    {
        <a class="btn btn-primary" href="/visitors/create">New Visitor</a>
    }
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (visitors.Count == 0)
{
    <div class="alert alert-info">No visitors found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Company</th>
                        <th>Vehicle Plate</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var visitor in visitors)
                {
                    <tr>
                        <td>@visitor.FullName</td>
                        <td>@visitor.Phone</td>
                        <td>@visitor.Company</td>
                        <td>@visitor.VehiclePlate</td>
                        <td>@visitor.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary" href="/visitors/@visitor.Id">View</a>
                                @if (MockAuth.HasPermission(DemoPermissions.VisitorsEdit))
                                {
                                    <a class="btn btn-outline-secondary" href="/visitors/@visitor.Id/edit">Edit</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<VisitorDto> visitors = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await MockAuth.InitializeAsync();

        try
        {
            visitors = (await VisitorService.GetVisitorsAsync()).ToList();
        }
        catch
        {
            errorMessage = "Failed to load visitors.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
