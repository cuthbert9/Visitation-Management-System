@page "/visits/create"
@inject VMS.Web.Services.IVisitService VisitService
@inject VMS.Web.Services.IVisitorService VisitorService
@inject VMS.Web.Services.IOfficeService OfficeService
@inject VMS.Web.Auth.MockAuthService MockAuth
@inject NavigationManager NavigationManager
@using System.Text.Json

<PageTitle>Schedule Visit</PageTitle>

<h1 class="mb-4">Schedule Visit</h1>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!MockAuth.HasPermission(DemoPermissions.VisitsCreate))
{
    <div class="alert alert-warning">Your current demo role cannot schedule visits.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <EditForm Model="request" OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Visitor</label>
                    <InputSelect class="form-select" @bind-Value="request.VisitorId">
                        <option value="0">Select visitor</option>
                        @foreach (var visitor in visitors)
                        {
                            <option value="@visitor.Id">@visitor.FullName</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Office</label>
                    <InputSelect class="form-select" @bind-Value="request.OfficeId">
                        <option value="0">Select office</option>
                        @foreach (var office in offices)
                        {
                            <option value="@office.Id">@office.Name (@office.OfficeCode)</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-3">
                    <label class="form-label">Visit Date</label>
                    <InputDate  class="form-control" @bind-Value="request.VisitDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Expected Arrival</label>
                    <InputDate class="form-control" @bind-Value="expectedArrivalDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Purpose</label>
                    <InputTextArea class="form-control" @bind-Value="request.Purpose" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Attachment URL</label>
                    <InputText class="form-control" @bind-Value="request.AttachmentUrl" />
                </div>

                <button class="btn btn-primary" type="submit" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Create Visit")
                </button>
            </EditForm>
        </div>
    </div>
}

@code {
    private VisitCreateDto request = new() { VisitDate = DateTime.Today };
    private DateTime? expectedArrivalDate = DateTime.Today;
    private List<VisitorDto> visitors = [];
    private List<OfficeDto> offices = [];
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await MockAuth.InitializeAsync();

        try
        {
            visitors = (await VisitorService.GetVisitorsAsync()).ToList();
            offices = (await OfficeService.GetOfficesAsync()).ToList();
        }
        catch
        {
            errorMessage = "Failed to load form data.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            request.CreatedById = null;
            request.ExpectedArrival = expectedArrivalDate;
            await VisitService.CreateVisitAsync(request);
            NavigationManager.NavigateTo("/visits");
        }
        catch (HttpRequestException ex)
        {
            errorMessage = TryExtractMessage(ex.Message) ?? "Failed to create visit.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string? TryExtractMessage(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return null;
        }

        try
        {
            var payload = JsonSerializer.Deserialize<ApiErrorResponse>(raw);
            return string.IsNullOrWhiteSpace(payload?.Message) ? raw : payload.Message;
        }
        catch
        {
            return raw;
        }
    }

    private sealed class ApiErrorResponse
    {
        public string? Message { get; set; }
    }
}
