@page "/visits/{Id:int}"
@inject VMS.Web.Services.IVisitService VisitService
@inject VMS.Web.Auth.MockAuthService MockAuth

<PageTitle>Visit Details</PageTitle>

<h1 class="mb-4">Visit Information</h1>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (visit is null)
{
    <div class="alert alert-warning">Visit not found.</div>
}
else
{
    var currentParking = visit.ParkingReservations.FirstOrDefault();

    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
        <p class="text-muted mb-0">Manage the current visit status.</p>
        <div class="btn-group flex-wrap">
            @if (MockAuth.HasPermission(DemoPermissions.VisitsApprove))
            {
                <button class="btn btn-outline-success" @onclick='() => ApplyActionAsync("approve")' disabled="@(isActing || visit.Status != VisitStatus.Pending)">Approve</button>
            }
            @if (MockAuth.HasPermission(DemoPermissions.VisitsReject))
            {
                <button class="btn btn-outline-danger" @onclick='() => ApplyActionAsync("reject")' disabled="@(isActing || visit.Status != VisitStatus.Pending)">Reject</button>
            }
            @if (MockAuth.HasPermission(DemoPermissions.VisitsCheckIn))
            {
                <button class="btn btn-outline-primary" @onclick='() => ApplyActionAsync("checkin")' disabled="@(isActing || visit.Status != VisitStatus.Approved)">Check In</button>
            }
            @if (MockAuth.HasPermission(DemoPermissions.VisitsCheckOut))
            {
                <button class="btn btn-outline-secondary" @onclick='() => ApplyActionAsync("checkout")' disabled="@(isActing || visit.Status != VisitStatus.CheckedIn)">Check Out</button>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Visitor</dt>
                <dd class="col-sm-9">@visit.Visitor.FullName</dd>

                <dt class="col-sm-3">Office</dt>
                <dd class="col-sm-9">@visit.Office.Name</dd>

                <dt class="col-sm-3">Visit Date</dt>
                <dd class="col-sm-9">@visit.VisitDate.ToLocalTime().ToString("f")</dd>

                <dt class="col-sm-3">Expected Arrival</dt>
                <dd class="col-sm-9">@(visit.ExpectedArrival?.ToLocalTime().ToString("f") ?? "Not specified")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@visit.Status</dd>

                <dt class="col-sm-3">Purpose</dt>
                <dd class="col-sm-9">@visit.Purpose</dd>

                <dt class="col-sm-3">Attachment</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(visit.AttachmentUrl) ? "No attachment" : visit.AttachmentUrl)</dd>

                <dt class="col-sm-3">Check In</dt>
                <dd class="col-sm-9">@(visit.LatestCheckIn?.CheckInTime.ToLocalTime().ToString("f") ?? "Not checked in")</dd>

                <dt class="col-sm-3">Check Out</dt>
                <dd class="col-sm-9">@(visit.LatestCheckOut?.CheckOutTime.ToLocalTime().ToString("f") ?? "Not checked out")</dd>

                <dt class="col-sm-3">Parking Status</dt>
                <dd class="col-sm-9">@(currentParking?.Status.ToString() ?? "No parking reservation")</dd>

                <dt class="col-sm-3">Parking Slot</dt>
                <dd class="col-sm-9">@(currentParking is null ? "No parking reservation" : string.IsNullOrWhiteSpace(currentParking.Zone) ? currentParking.SlotCode : $"{currentParking.SlotCode} ({currentParking.Zone})")</dd>

                <dt class="col-sm-3">Vehicle Plate</dt>
                <dd class="col-sm-9">@(currentParking?.VehiclePlate ?? "Not provided")</dd>

                <dt class="col-sm-3">Reserved At</dt>
                <dd class="col-sm-9">@(currentParking?.ReservedAt?.ToLocalTime().ToString("f") ?? "Not reserved")</dd>

                <dt class="col-sm-3">Released At</dt>
                <dd class="col-sm-9">@(currentParking?.ReleasedAt?.ToLocalTime().ToString("f") ?? "Not released")</dd>
            </dl>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private VisitDto? visit;
    private bool isLoading = true;
    private bool isActing;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await MockAuth.InitializeAsync();
        await LoadVisitAsync();
    }

    private async Task LoadVisitAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            visit = await VisitService.GetVisitByIdAsync(Id);
        }
        catch
        {
            errorMessage = "Failed to load visit details.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyActionAsync(string action)
    {
        isActing = true;
        errorMessage = null;

        try
        {
            var actorId = MockAuth.CurrentSession?.ActorId ?? 0;

            visit = action switch
            {
                "approve" => await VisitService.ApproveVisitAsync(Id, new VisitApprovalDto { ApprovedById = actorId }),
                "reject" => await VisitService.RejectVisitAsync(Id, new VisitApprovalDto { ApprovedById = actorId }),
                "checkin" => await VisitService.CheckInVisitAsync(Id, new VisitCheckInDto { CheckedInById = actorId, Gate = "Main Gate" }),
                "checkout" => await VisitService.CheckOutVisitAsync(Id, new VisitCheckOutDto { CheckedOutById = actorId, Remarks = "Processed in demo mode" }),
                _ => visit
            };
        }
        catch
        {
            errorMessage = "Failed to update visit status.";
        }
        finally
        {
            isActing = false;
        }
    }
}
